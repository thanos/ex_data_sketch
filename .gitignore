# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
ex_data_sketch-*.tar

# Temporary files, for example, from tests.
/tmp/

/priv/plts

/bench/output/

# Rust NIF build artifacts
/native/ex_data_sketch_nif/target/
/priv/native/

# Precompiled NIF checksums. Regenerated by .github/workflows/release.yml
# during `publish_hex` (via `mix rustler_precompiled.download --all --print`)
# right before `mix hex.publish`. Never commit this file: a stale committed
# value would mask a real "release pipeline regenerated nothing" bug at
# publish time and would also produce confusing checksum mismatches for
# users installing from git rather than from Hex.
/checksum-Elixir.ExDataSketch.Nif.exs
